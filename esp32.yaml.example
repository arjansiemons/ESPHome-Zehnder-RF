substitutions:
  devicename: zehnder_sniffer
  upper_devicename: Zehnder Sniffer

esphome:
  name: zehnder-sniffer
  comment: Zehnder RF Sniffer and Controller

esp32:
  board: esp32dev
  framework:
    type: arduino

# Enable logging
logger:
  level: DEBUG
  baud_rate: 115200

# WiFi configuratie
wifi:
  ssid: !secret wifi_ssid
  password: !secret wifi_password

  # Enable fallback hotspot
  ap:
    ssid: "Zehnder-Sniffer"
    password: !secret fallback_password

captive_portal:

# Load external components - gebruik GitHub repository
external_components:
  - source:
      type: git
      url: https://github.com/arjansiemons/ESPHome-Zehnder-RF
      ref: main
    components: [ nrf905, zehnder ]

# SPI configuratie voor ESP32
spi:
  clk_pin: GPIO18   # VSPI CLK
  mosi_pin: GPIO23  # VSPI MOSI
  miso_pin: GPIO19  # VSPI MISO

# nRF905 configuratie
nrf905:
  id: "nrf905_rf"
  cs_pin: GPIO5     # CSN
  cd_pin: GPIO4     # Carrier Detect
  ce_pin: GPIO16    # Chip Enable
  pwr_pin: GPIO17   # Power
  txen_pin: GPIO2   # TX Enable

# The FAN controller
fan:
  - platform: zehnder
    id: zehnder_fan
    name: "Zehnder Ventilation"
    nrf905: nrf905_rf
    update_interval: "60s"

# Handige buttons voor testen
button:
  - platform: restart
    id: ${devicename}_restart
    name: ${upper_devicename} Restart

  - platform: template
    id: ${devicename}_high_10
    name: ${upper_devicename} High 10min
    on_press:
      then:
        lambda: |-
          zehnder_fan->setSpeed(3, 10);

  - platform: template
    id: ${devicename}_medium
    name: ${upper_devicename} Medium
    on_press:
      then:
        lambda: |-
          zehnder_fan->setSpeed(2, 0);

# Service voor manueel speed instellen
api:
  services:
    - service: set_speed
      variables:
        speed: int
        timer: int
      then:
        - lambda: |-
            zehnder_fan->setSpeed(speed, timer);
